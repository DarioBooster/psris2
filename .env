# ============================================================
# P@SRIS2 — Variables d'environnement
# Copiez ce fichier en .env et adaptez les valeurs
# NE JAMAIS commiter le fichier .env dans git !
# ============================================================

# Port du serveur (Railway utilise PORT automatiquement)
PORT=3000

# Environnement (development | production)
NODE_ENV=production

# Secret JWT — CHANGEZ CETTE VALEUR en production !
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=changez_ce_secret_en_production_psris2_2025_borgou

# Chemin vers la base de données SQLite
# En production Railway, utiliser /data/psris2.db pour persistance
DB_PATH=./db/psris2.db
